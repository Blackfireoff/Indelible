{
  "name": "indelible",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@xenova/transformers$": "<rootDir>/tests/__mocks__/@xenova/transformers.ts"
    }
  },
  "dependencies": {
    "@0glabs/0g-serving-broker": "^0.7.4",
    "@xenova/transformers": "^2.17.2",
    "ethers": "^6.13.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.5.0",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jest": "^29.7.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  }
}
