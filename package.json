{
  "name": "indelible",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "env:merge": "node scripts/merge-subproject-envs.mjs",
    "pipeline:dev2:file": "node scripts/run-dev2-from-file.mjs",
    "pipeline:chain": "node scripts/run-dev1-dev2.mjs",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@xenova/transformers$": "<rootDir>/tests/__mocks__/@xenova/transformers.ts"
    }
  },
  "dependencies": {
    "@base-org/account": "^2.5.3",
    "@chainlink/contracts": "^1.5.0",
    "@coinbase/wallet-sdk": "^4.3.7",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@metamask/connect-evm": "^0.9.1",
    "@openzeppelin/contracts": "^5.6.1",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19",
    "@tanstack/react-query": "^5.96.2",
    "@wagmi/connectors": "^8.0.0",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "@0glabs/0g-serving-broker": "^0.7.4",
    "@0glabs/0g-ts-sdk": "^0.3.3",
    "@xenova/transformers": "^2.17.2",
    "ethers": "^6.13.0",
    "next": "16.2.2",
    "porto": "^0.2.37",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.47.10",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "esbuild": "^0.28.0",
    "@types/jest": "^29.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jest": "^29.7.0",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "ts-jest": "^29.1.0"
  }
}
