# ─────────────────────────────────────────────────────────────────────────────
# 0G Storage (Galileo testnet, chainId 16602)
# ─────────────────────────────────────────────────────────────────────────────
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
# Turbo vs standard: https://docs.0g.ai/developer-hub/building-on-0g/storage/sdk
ZEROG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
# Optional: poll several indexers until getFileLocations returns nodes (turbo often lags; standard may know the file first).
# ZEROG_INDEXER_FALLBACK_URLS=https://indexer-storage-testnet-standard.0g.ai
# Or replace both with an explicit ordered list (first URL is used for upload):
# ZEROG_INDEXER_URLS=https://indexer-storage-testnet-turbo.0g.ai,https://indexer-storage-testnet-standard.0g.ai
ZEROG_PRIVATE_KEY=your_private_key_here

# Upload tuning (same knobs as 0g-storage-ts-starter-kit src/config.ts + src/storage.ts)
# ZEROG_UPLOAD_MAX_RETRIES=5
# ZEROG_UPLOAD_RETRY_INTERVAL_SEC=5
# ZEROG_MAX_GAS_PRICE=0
# ZEROG_GAS_PRICE=
# ZEROG_GAS_LIMIT=
# Set ZEROG_UPLOAD_MAX_RETRIES=0 to use SDK-internal defaults only
#
# After upload, poll the indexer until storage nodes appear (best for immediate download).
# Increase if you see "Indexer did not return storage locations" right after a successful TX.
# ZEROG_INDEXER_SYNC_TIMEOUT_MS=120000
# ZEROG_INDEXER_SYNC_INTERVAL_MS=3000
#
# Default: if this wait times out, the pipeline still returns the Merkle root and writes the manifest
# (downloads may fail until the indexer catches up). Set to "true" to fail the upload instead (strict).
# ZEROG_STRICT_INDEXER_SYNC_AFTER_UPLOAD=false
#
# JSON shape for uploads (see README "Why some artifacts fail on 0G")
# ZEROG_UPLOAD_MINIFY_JSON=true
# ZEROG_UPLOAD_PAD_MIN_BYTES=2048

# ─────────────────────────────────────────────────────────────────────────────
# Local embeddings (no API key required)
# ─────────────────────────────────────────────────────────────────────────────
# "local"  → downloads Xenova/all-MiniLM-L6-v2 on first run (~20 MB)
# "stub"   → zero vectors (fast, for testing)
# "openai" → requires OPENAI_API_KEY below
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# ─────────────────────────────────────────────────────────────────────────────
# LLM — extraction des statements (clean_article → statements.json)
# ─────────────────────────────────────────────────────────────────────────────
# Même variables que l’ancien « refinement » : `LLM_REFINEMENT_PROVIDER`, LOCAL_LLM_*, LLM_0G_*.
# Si l’endpoint local ou l’init 0G échoue, l’extraction renvoie 0 statement (pas de repli regex dans le job).
#
# Provider: "local" = LM Studio / OpenAI-compatible | "0g" = 0G Compute
# LLM_REFINEMENT_PROVIDER=local
#
# ─── Local (LM Studio, etc.) ───
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_API_KEY=lm-studio
LOCAL_LLM_MODEL=qwen2.5-7b-instruct
LOCAL_LLM_TIMEOUT_MS=60000
#
# ─── 0G Compute (requires @0glabs/0g-serving-broker; same wallet idea as dev3-AI-RAG) ───
# LLM_REFINEMENT_PROVIDER=0g
# Uses ZEROG_PRIVATE_KEY by default, or override for inference-only:
# LLM_0G_PRIVATE_KEY=
# LLM_0G_RPC_URL=https://evmrpc-testnet.0g.ai
# Optional: skip discovery and pin a provider contract address
# LLM_0G_PROVIDER_ADDRESS=
# Optional: model id sent to /chat/completions (else service metadata model)
# LLM_0G_MODEL=qwen/qwen-2.5-7b-instruct
# LLM_0G_MAX_TOKENS=2048

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI (optional, only needed if EMBEDDING_PROVIDER=openai)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─────────────────────────────────────────────────────────────────────────────
# Pipeline configuration
# ─────────────────────────────────────────────────────────────────────────────
# "zerog" for real 0G Storage, "mock" for local dev/testing
STORAGE_ADAPTER=mock
OUTPUT_DIR=./output

# Copie locale organisée de tous les JSON du run (en plus du dépôt 0G/mock) :
#   OUTPUT_DIR/archives/<YYYY-MM-DD_HHMMSS>_<attestation>/
# Fichiers : raw_capture, clean_article, statements, verified_statements, retrieval_chunks,
# embeddings, document_manifest, run_meta.json (récap + adresses).
# Désactiver : LOCAL_ARTIFACT_ARCHIVE=false
# LOCAL_ARTIFACT_ARCHIVE=true

# (Optionnel) Doublon plat historique sous OUTPUT_DIR/local-artifacts/ — utile pour scripts anciens.
# SAVE_ARTIFACTS_BEFORE_UPLOAD=true
# LOCAL_ARTIFACTS_SUBDIR=local-artifacts

# Path to raw capture JSON produced by Dev 1
RAW_CAPTURE_PATH=./src/fixtures/sample-raw-capture.json
# Or provide the 0G data address directly:
# RAW_CAPTURE_DATA_ADDRESS=0xabc123...

# ─────────────────────────────────────────────────────────────────────────────
# Worker (npm run worker) — poll Dev1 registry, run ingestion per new item
# ─────────────────────────────────────────────────────────────────────────────
# JSON list: [ { "id": "<stable-id>", "rawCaptureDataAddress": "0x..." }, ... ]
# or { "items": [ ... ] }. Prefer HTTPS in prod:
# DEV1_REGISTRY_URL=https://example.com/dev1-registry.json
# DEV1_REGISTRY_PATH=./path/to/registry.json
#
# Idempotency + retries (local JSON file by default):
# WORKER_STATE_PATH=./data/worker-state.json
# WORKER_POLL_INTERVAL_MS=30000
# WORKER_STALE_PROCESSING_MS=1800000
# WORKER_MAX_RETRIES=5
# SKIP_STORAGE_VERIFY=true
